{
  "name": "yggdrasil",
  "private": true,
  "version": "0.1.45",
  "type": "module",
  "main": "electron/main.mjs",
  "overrides": {
    "onnxruntime-web": "1.23.2"
  },
  "scripts": {
    "dev": "cross-env BUILD_TARGET=web vite",
    "dev:local": "cross-env BUILD_TARGET=local vite",
    "dev:electron": "cross-env BUILD_TARGET=electron vite",
    "build": "cross-env BUILD_TARGET=web tsc -b && cross-env BUILD_TARGET=web vite build",
    "build:web": "cross-env BUILD_TARGET=web tsc -b && cross-env BUILD_TARGET=web vite build",
    "build:electron": "cross-env BUILD_TARGET=electron tsc -b && cross-env BUILD_TARGET=electron vite build",
    "build:electron:main": "node electron/esbuild.main.mjs",
    "build:server": "cd ../../server && npm run build",
    "rebuild:server": "cd ../../server && npm rebuild better-sqlite3 --runtime=electron --target=34.0.0 --dist-url=https://electronjs.org/headers --build-from-source",
    "rebuild:client": "electron-rebuild -f -w better-sqlite3",
    "build:win": "npm run build:server && npm run build:electron && npm run build:electron:main && electron-builder --win",
    "build:linux": "npm run build:server && npm run build:electron && npm run build:electron:main && electron-builder --linux",
    "build:mac": "npm run build:server && npm run build:electron && npm run build:electron:main && electron-builder --mac",
    "build:all": "npm run build:electron && npm run build:electron:main && electron-builder --win --linux",
    "lint": "eslint .",
    "preview": "vite preview",
    "predev": "node scripts/check-env.js",
    "electron": "electron .",
    "package:electron": "electron-builder"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.5",
    "@huggingface/transformers": "^3.8.1",
    "@mdxeditor/editor": "^3.40.1",
    "@reduxjs/toolkit": "^2.8.2",
    "@stripe/stripe-js": "^8.0.0",
    "@supabase/supabase-js": "^2.58.0",
    "@tailwindcss/vite": "^4.1.10",
    "@tanstack/query-sync-storage-persister": "^5.90.2",
    "@tanstack/react-query": "^5.90.2",
    "@tanstack/react-query-devtools": "^5.90.2",
    "@tanstack/react-query-persist-client": "^5.90.2",
    "@tanstack/react-virtual": "^3.13.18",
    "@types/three": "^0.182.0",
    "@vercel/analytics": "^1.6.1",
    "@xyflow/react": "^12.8.2",
    "adm-zip": "^0.5.16",
    "ajv": "^8.17.1",
    "ajv-formats": "^2.1.1",
    "atomically": "^2.1.0",
    "boxicons": "^2.1.4",
    "clsx": "^2.1.1",
    "conf": "^12.0.0",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "debounce-fn": "^5.1.2",
    "dexie": "^4.0.11",
    "env-paths": "^3.0.0",
    "express": "^4.21.2",
    "framer-motion": "^12.23.12",
    "glob": "^13.0.0",
    "gsap": "^3.14.2",
    "highlight.js": "^11.11.1",
    "json-schema-typed": "^8.0.2",
    "katex": "^0.16.27",
    "lucide-react": "^0.516.0",
    "mammoth": "^1.11.0",
    "onnxruntime-web": "1.23.2",
    "openwakeword-wasm-browser": "^0.1.1",
    "pdfjs-dist": "^5.4.449",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.6.2",
    "rehype-highlight": "^4.0.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "sanitize-html": "^2.17.0",
    "strip-markdown": "^6.0.0",
    "three": "^0.182.0",
    "tokenx": "^1.2.1",
    "uint8array-extras": "^0.3.0",
    "unified": "^11.0.5",
    "unique-names-generator": "^4.7.1",
    "uuid": "^11.1.0",
    "ws": "^8.18.3",
    "yaml": "^2.8.2"
  },
  "optionalDependencies": {
    "@electron/get": "^2.0.3",
    "@electron/rebuild": "^4.0.1",
    "better-sqlite3": "^11.8.1",
    "bindings": "^1.5.0",
    "electron": "34.0.0",
    "electron-builder": "^26.0.0",
    "electron-rebuild": "^3.2.9",
    "electron-updater": "^6.6.2",
    "file-uri-to-path": "^2.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@tailwindcss/typography": "^0.5.16",
    "@types/adm-zip": "^0.5.7",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/dagre": "^0.7.53",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/sanitize-html": "^2.16.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react-swc": "^3.9.0",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "esbuild": "^0.27.1",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.11",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vite-plugin-static-copy": "^3.1.4"
  }
}
