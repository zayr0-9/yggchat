{
  "electronVersion": "34.0.0",
  "appId": "com.yggdrasil.chat",
  "icon": "public/img/taskbar-logo.png",
  "productName": "Yggdrasil",
  "directories": {
    "output": "release"
  },
  "artifactName": "Yggdrasil-${version}-${os}-${arch}.${ext}",
  "files": ["dist-electron/**/*", "electron/main.mjs", "electron/preload.mjs"],
  "asarUnpack": [
    "**/node_modules/better-sqlite3/**/*",
    "**/node_modules/bindings/**/*",
    "**/node_modules/file-uri-to-path/**/*",
    "**/node_modules/electron-updater/**/*"
  ],
  "extraResources": [
    {
      "from": "custom-tools/CUSTOM_TOOLS_GUIIDE.md",
      "to": "custom-tools/CUSTOM_TOOLS_GUIIDE.md"
    }
  ],
  "win": {
    "target": ["nsis"]
  },
  "mac": {
    "target": ["dmg"],
    "category": "public.app-category.productivity"
  },
  "linux": {
    "target": ["AppImage"],
    "category": "Office"
  },
  "npmRebuild": true,
  "nativeRebuilder": "sequential",
  "publish": [
    {
      "provider": "generic",
      "url": "https://awvlmkkdnwmpgomsuneb.supabase.co/storage/v1/object/public/updates/updates"
    }
  ]
}
