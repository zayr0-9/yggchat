{
  "electronVersion": "38.8.4",
  "appId": "com.graviton.chat",
  "icon": "public/img/graviton-dark1.ico",
  "productName": "Graviton",
  "directories": {
    "output": "release"
  },
  "artifactName": "Graviton-${version}-${os}-${arch}.${ext}",
  "files": [
    "dist-electron/**/*",
    "electron/main.mjs",
    "electron/preload.mjs",
    "electron/toolRuntimeUtility.mjs",
    "electron/headlessServer/ui/mobile/**/*",
    "electron/headlessServer/routes/**/*.html"
  ],
  "asarUnpack": [
    "**/node_modules/better-sqlite3/**/*",
    "**/node_modules/bindings/**/*",
    "**/node_modules/file-uri-to-path/**/*",
    "**/node_modules/electron-updater/**/*",
    "**/node_modules/node-pty/**/*"
  ],
  "extraResources": [
    {
      "from": "custom-tools/CUSTOM_TOOLS_GUIIDE.md",
      "to": "custom-tools/CUSTOM_TOOLS_GUIIDE.md"
    },
    {
      "from": ".ygg/settings.local.json",
      "to": ".ygg/settings.local.json"
    },
    {
      "from": ".ygg/hooks",
      "to": ".ygg/hooks"
    },
    {
      "from": ".ygg/custom-themes",
      "to": ".ygg/custom-themes"
    }
  ],
  "win": {
    "target": ["nsis"],
    "icon": "public/img/graviton-dark1.ico"
  },
  "mac": {
    "target": ["dmg"],
    "category": "public.app-category.productivity"
  },
  "linux": {
    "target": ["AppImage"],
    "category": "Office"
  },
  "npmRebuild": true,
  "nativeRebuilder": "sequential",
  "publish": [
    {
      "provider": "generic",
      "url": "https://awvlmkkdnwmpgomsuneb.supabase.co/storage/v1/object/public/updates/updates"
    }
  ]
}
