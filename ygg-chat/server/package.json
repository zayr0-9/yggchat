{
  "name": "ygg-chat-server",
  "version": "1.0.0",
  "description": "Backend API server for Ollama Chat and other apis",
  "main": "dist/server/src/index.js",
  "scripts": {
    "migrate": "ts-node src/database/runMigration.ts",
    "update-projects": "ts-node src/database/updateProjectsUserId.ts",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:migrate": "npm run migrate && npm run dev",
    "build": "tsc",
    "start": "node dist/server/src/index.js",
    "type-check": "tsc --noEmit",
    "test:supabase": "ts-node src/database/testSupabase.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.4",
    "@ai-sdk/google": "^2.0.3",
    "@ai-sdk/openai": "^2.0.14",
    "@ai-sdk/openai-compatible": "^1.0.18",
    "@anthropic-ai/claude-agent-sdk": "^0.1.30",
    "@anthropic-ai/sdk": "^0.68.0",
    "@modelcontextprotocol/sdk": "^1.20.0",
    "@openrouter/ai-sdk-provider": "^1.2.0",
    "@openrouter/sdk": "^0.1.27",
    "@supabase/supabase-js": "^2.58.0",
    "ai": "^5.0.6",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "decimal.js": "^10.6.0",
    "dotenv": "^16.3.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.1.0",
    "glob": "^11.0.3",
    "helmet": "^7.0.0",
    "ioredis": "^5.8.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "node-fetch": "^3.3.2",
    "openai": "^5.23.0",
    "playwright": "^1.40.0",
    "rate-limit-redis": "^4.2.3",
    "strip-markdown": "^6.0.0",
    "stripe": "19.1.0",
    "tree-sitter": "^0.21.1",
    "tree-sitter-javascript": "^0.23.1",
    "tree-sitter-json": "^0.24.8",
    "tree-sitter-typescript": "^0.23.2",
    "uuid": "^13.0.0",
    "ws": "^8.18.3",
    "zod": "^3.22.2"
  },
  "optionalDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/compression": "^1.7.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/glob": "^8.1.0",
    "@types/morgan": "^1.9.4",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.5.9",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "nodemon": "^3.0.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  }
}
